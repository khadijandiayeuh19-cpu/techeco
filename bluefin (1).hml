<body>
  <!-- Barre d'annonce -->
  <div class="topbar">
    <div class="container">
      <span>Ecotech • Solutions solaires, électriques & sécurité • Dakar</span>
      <a class="cta" href="#contact">Demander un devis</a>
    </div>
  </div>

  <!-- Navigation -->
  <header class="header">
    <div class="container nav">
      <a class="brand" href="#hero" aria-label="Accueil Ecotech">
        <img src="copilot1.png" alt="Ecotech" />
      </a>
      <nav class="menu" aria-label="Navigation principale">
        <a href="#solutions">Solutions</a>
        <a href="#produits">Produits</a>
        <a href="#projets">Projets</a>
